{
  "env": {
    "browser": true,
    "es2021": true,
    "jquery": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "bootstrap": "readonly",
    "fetchData": "readonly",
    "formatDate": "readonly",
    "formatDateLong": "readonly",
    "formatCurrency": "readonly",
    "getLoggedAdmin": "readonly",
    "saveAdmin": "readonly",
    "logoutAdmin": "readonly",
    "requireAuth": "readonly",
    "getStatusBadgeClass": "readonly",
    "truncateText": "readonly",
    "getUrlParam": "readonly",
    "API_BASE": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single"],
    "indent": ["warn", 2],
    "no-undef": "warn"
  }
}
